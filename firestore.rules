// ═══════════════════════════════════════════════════════════════
// FILE: firestore.rules
// ROLE IN KULA: The "Security Perimeter" — the ONLY thing standing between
// the public internet and your community's data.
//
// HOW FIRESTORE RULES WORK:
//   Every time ANY code in the app tries to read/write data to Firestore,
//   Google's servers check these rules FIRST. If the rules say "deny",
//   the operation fails and firebase.ts → handleFirestoreError() catches it.
//   These rules run SERVER-SIDE — the user cannot bypass them.
//   Cloud Functions use the Admin SDK, which BYPASSES these rules entirely;
//   anything marked "server-only" below is written by functions/src/*.
//
// SECURITY LAYERS:
//   1. isSignedIn(): Most basic check — you must have a Firebase Auth session.
//   2. isOwner(userId): You can only modify YOUR OWN data.
//   3. isAdmin(): Custom-claim check (request.auth.token.admin), set via
//      scripts/grant-admin.ts. Free and instant — no Firestore read.
//   4. Field-level validation: create/update rules pin authorship fields
//      (ownerId, senderId, fromUserId, actorId, createdBy) to the caller
//      and block self-service writes to reputation/privilege fields.
// ═══════════════════════════════════════════════════════════════
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // isAdmin(): Reads the custom claim embedded in the auth token.
    // Set via scripts/grant-admin.ts (Admin SDK setCustomUserClaims).
    // Unlike the old get()-based check, this costs NO Firestore read.
    function isAdmin() {
      return isSignedIn() && request.auth.token.get('admin', false) == true;
    }

    // Which fields does this write change?
    function changedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Is the caller a member of the given circle?
    function isCircleMember(circleId) {
      return exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
    }

    // Can the caller see this chat document's data?
    // DIRECT chats: must be a participant.
    // CHANNEL chats: participants is [] by design — access = circle membership.
    function canAccessChatData(chat) {
      return chat.get('participants', []).hasAny([request.auth.uid])
        || (chat.get('type', 'DIRECT') == 'CHANNEL'
            && chat.get('circleId', '') != ''
            && isCircleMember(chat.circleId));
    }

    // Same check for subcollections (messages/replies), resolving the parent chat.
    function canAccessChat(chatId) {
      return isSignedIn()
        && canAccessChatData(get(/databases/$(database)/documents/chats/$(chatId)).data);
    }

    // ─── Users ────────────────────────────────────────────
    // Collection: users/{userId}
    match /users/{userId} {
      // READ: Any authenticated user can read profiles.
      // The trust network (useTrustNetwork.ts) needs broad node access;
      // visibility filtering happens client-side (trustGraph.ts).
      // NOTE: exact coordinates are NOT here — they live in users_private.
      allow read: if isSignedIn();

      // CREATE: Only your own profile, and you cannot grant yourself
      // privileges or reputation at birth.
      allow create: if isOwner(userId)
        && request.resource.data.get('isAdmin', false) == false
        && request.resource.data.get('isVerified', false) == false
        && request.resource.data.get('rating', 0) == 0
        && request.resource.data.get('reviewCount', 0) == 0
        && request.resource.data.get('hostStatus', 'NONE') in ['NONE', 'PENDING']
        && !request.resource.data.keys().hasAny(['trustMosaic', 'hostId']);

      // UPDATE:
      //  - Owner: anything EXCEPT privilege/reputation/host fields.
      //    (hostId/hostStatus are set server-side by the applyInviteCode
      //    Cloud Function; trustMosaic by the onGratitudeCreated trigger.)
      //  - Owner exception: may CLEAR their own host connection
      //    (Profile → "remove host") — a pure downgrade, never an escalation.
      //  - Host: may update ONLY hostStatus on their guest's profile
      //    (approve/decline from the Waiting Room flow).
      //  - Admin: anything (moderation).
      allow update: if isAdmin()
        || (isOwner(userId)
            && !changedKeys().hasAny(
                 ['isAdmin', 'isVerified', 'rating', 'reviewCount',
                  'trustMosaic', 'hostId', 'hostStatus']))
        || (isOwner(userId)
            && changedKeys().hasOnly(['hostId', 'hostStatus'])
            && request.resource.data.get('hostId', null) == null
            && request.resource.data.get('hostStatus', 'NONE') == 'NONE')
        || (isSignedIn()
            && request.auth.uid == resource.data.get('hostId', '')
            && changedKeys().hasOnly(['hostStatus']));

      // DELETE: Only admins (banning). GDPR self-deletion goes through
      // DeleteAccountSheet → status:'DELETED' → server-side hard delete.
      allow delete: if isAdmin();
    }

    // ─── Private User Data ────────────────────────────────
    // Collection: users_private/{userId}
    // Contains: exactHomeLocation, savedLocations (precise coordinates).
    match /users_private/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ─── Items (Asks, Shares, İmece, Missions, Joins, Flow) ─
    // Collection: items/{itemId}
    match /items/{itemId} {
      allow read: if isSignedIn();

      // CREATE: ownerId is pinned to the caller (no impersonation),
      // items start ACTIVE with an empty participants list.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.get('status', 'ACTIVE') == 'ACTIVE'
        && request.resource.data.get('participants', []).size() == 0;

      // UPDATE: owner/admin freely; everyone else may ONLY add or remove
      // THEMSELVES from the participants array (join/leave an İmece).
      allow update: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid
        || isAdmin()
        || (changedKeys().hasOnly(['participants']) && onlyTogglesSelfParticipation())
      );

      allow delete: if isSignedIn()
        && (resource.data.ownerId == request.auth.uid || isAdmin());

      function onlyTogglesSelfParticipation() {
        let before = resource.data.get('participants', []).toSet();
        let after = request.resource.data.get('participants', []).toSet();
        let added = after.difference(before);
        let removed = before.difference(after);
        return (added == [request.auth.uid].toSet() && removed.size() == 0)
            || (removed == [request.auth.uid].toSet() && added.size() == 0);
      }

      // Comments sub-collection: items/{itemId}/comments/{commentId}
      match /comments/{commentId} {
        allow read: if isSignedIn();
        // Authorship pinned: you can only comment as yourself.
        allow create: if isSignedIn()
          && request.resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn()
          && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // ─── Circles ──────────────────────────────────────────
    // Collection: circles/{circleId}
    match /circles/{circleId} {
      allow read: if isSignedIn();

      // CREATE: creatorId pinned to caller. memberCount starts at 0 —
      // the onCircleMemberCreated trigger (functions/src/social.ts)
      // maintains the count when the creator's member doc is written.
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.get('memberCount', 0) == 0;

      // UPDATE: creator or admin only. memberCount/privacy maintenance
      // moved server-side (Admin SDK bypasses rules), so the old
      // "anyone may write memberCount" exception is gone.
      allow update: if isSignedIn()
        && (resource.data.creatorId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn()
        && (resource.data.creatorId == request.auth.uid || isAdmin());

      // Members sub-collection: circles/{circleId}/members/{memberId}
      // Doc ID == member's UID. You may only join/leave as YOURSELF, and
      // only PUBLIC ("anyone can join") or HIDDEN ("invite-only" = you know
      // the circle ID/code) circles allow self-join. PRIVATE circles promise
      // approval, so self-joins are denied server-side; an approval flow can
      // later admit members via a Cloud Function (Admin SDK bypasses this).
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isOwner(memberId)
          && get(/databases/$(database)/documents/circles/$(circleId)).data.privacy != 'PRIVATE';
        allow delete: if isSignedIn() && (memberId == request.auth.uid || isAdmin());
      }
    }

    // ─── Chats ────────────────────────────────────────────
    // Collection: chats/{chatId}
    // DIRECT: 1:1, participants [uidA, uidB].
    // CHANNEL: circle chat, participants [] — access via circle membership.
    match /chats/{chatId} {
      // resource == null: reading a not-yet-existing chat doc must return
      // "doesn't exist" rather than permission-denied — Circles.openChannel
      // does getDoc() before creating a channel chat with a deterministic ID.
      allow read: if isSignedIn()
        && (resource == null || canAccessChatData(resource.data));

      allow create: if isSignedIn() && (
        (request.resource.data.get('type', '') == 'DIRECT'
          && request.resource.data.participants.hasAny([request.auth.uid])
          && request.resource.data.participants.size() == 2)
        || (request.resource.data.get('type', '') == 'CHANNEL'
          && request.resource.data.get('circleId', '') != ''
          && isCircleMember(request.resource.data.circleId)
          && request.resource.data.get('participants', []).size() == 0)
      );

      // UPDATE: members may update preview/read-state fields, but can never
      // rewrite the membership or identity of the chat itself.
      allow update: if isSignedIn()
        && canAccessChatData(resource.data)
        && !changedKeys().hasAny(['participants', 'type', 'circleId']);

      allow delete: if isAdmin();

      // Messages sub-collection: chats/{chatId}/messages/{messageId}
      match /messages/{messageId} {
        allow read: if canAccessChat(chatId);
        // senderId pinned: you can only send as yourself.
        allow create: if canAccessChat(chatId)
          && request.resource.data.senderId == request.auth.uid;
        // Members may vote on polls, claim urgent needs, and bump thread
        // counts — but cannot edit each other's message text.
        allow update: if canAccessChat(chatId)
          && changedKeys().hasOnly(['poll', 'metadata', 'replyCount']);
        allow delete: if isAdmin();

        // Thread replies: chats/{chatId}/messages/{messageId}/replies/{replyId}
        // (Previously unmatched by any rule — threads were silently denied.)
        match /replies/{replyId} {
          allow read: if canAccessChat(chatId);
          allow create: if canAccessChat(chatId)
            && request.resource.data.senderId == request.auth.uid;
          allow update: if canAccessChat(chatId)
            && changedKeys().hasOnly(['poll', 'metadata']);
          allow delete: if isAdmin();
        }
      }
    }

    // ─── Swipes ───────────────────────────────────────────
    // Collection: swipes/{swipeId}
    match /swipes/{swipeId} {
      allow read: if isSignedIn() && resource.data.swiperId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.swiperId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Notifications ────────────────────────────────────
    // Collection: notifications/{notifId}
    // Created client-side by social actions (Feed, PublicProfile, BridgeSheet,
    // Discovery, lib/notifications.ts); the onNotificationCreated function
    // sends the push. actorId pins WHO generated the notification, so
    // "from" identity cannot be forged.
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.userId is string
        && request.resource.data.get('content', '') is string
        && request.resource.data.get('content', '').size() <= 500;
      // Recipients may only flip read-state.
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && changedKeys().hasOnly(['isRead']);
      allow delete: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ─── Gratitude Notes ──────────────────────────────────
    // Collection: gratitude_notes/{noteId}
    // trustMosaic counters are updated by the onGratitudeCreated trigger,
    // NOT by the client — clients can no longer inflate reputations.
    match /gratitude_notes/{noteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.get('text', '').size() <= 1000;
      allow delete: if isAdmin();
    }

    // ─── Vouches ──────────────────────────────────────────
    // Collection: vouches/{vouchId}
    // The trust graph is built from ACCEPTED vouches, so transitions are
    // strict: only the RECIPIENT can accept/decline, exactly once,
    // and only the status field may change. Senders may withdraw (delete).
    match /vouches/{vouchId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.get('status', '') == 'PENDING';
      allow update: if isSignedIn()
        && resource.data.toUserId == request.auth.uid
        && resource.data.status == 'PENDING'
        && changedKeys().hasOnly(['status'])
        && request.resource.data.status in ['ACCEPTED', 'DECLINED'];
      allow delete: if isSignedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid
            || isAdmin());
    }

    // ─── Reviews ──────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.reviewerId == request.auth.uid;
    }

    // ─── Reports ───────────────────────────────────────────
    // App Store compliance: Apple requires a "Report" mechanism for UGC apps.
    match /reports/{reportId} {
      allow read: if isSignedIn() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Invites ──────────────────────────────────────────
    // Collection: invites/{code}
    // The full lifecycle is server-side (functions/src/invites.ts):
    // createInvite writes codes, lookupInvite resolves them, applyInviteCode
    // redeems them. Clients can only LIST their own codes — so codes cannot
    // be enumerated, probed for existence, or forged.
    match /invites/{code} {
      // Creators see their own invites (Profile invite manager); admins see all.
      allow read: if isSignedIn()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
      // Creation/redemption are Cloud Function (Admin SDK) only.
      allow create: if false;
      // Creators may expire their own un-used codes; redemption is server-side.
      allow update: if isSignedIn()
        && resource.data.createdBy == request.auth.uid
        && changedKeys().hasOnly(['status'])
        && request.resource.data.status == 'EXPIRED';
      allow delete: if isSignedIn()
        && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // ─── Test Connection Doc ──────────────────────────────
    // Used by: firebase.ts → testConnection() at boot time.
    match /test/{docId} {
      allow read: if isSignedIn();
    }
  }
}
