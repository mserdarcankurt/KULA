rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Item media: items/uploads/{ownerUid}/<file>
    // The ONLY client upload path (PostItem.tsx). Owners manage their own
    // folder; any signed-in user can read (item photos are shown in the feed,
    // and existing getDownloadURL token links keep working regardless).
    match /items/uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid == userId
                            && request.resource.size < 25 * 1024 * 1024
                            && (request.resource.contentType.matches('image/.*')
                                || request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else: no client access. Server-side (Admin SDK) bypasses rules.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
